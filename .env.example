# ──────────────────────────────────────────────────────────────────────────────
# .env.example — copy to apps/server/.env and fill in your real values
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Use local Postgres or a free cloud instance (recommended: https://neon.tech)
DATABASE_URL=postgresql://user:password@host:5432/healosbench

# ── Authentication ────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
BETTER_AUTH_SECRET=minimum-32-character-random-string-change-me

# URL of THIS server (the Hono backend)
# Local: http://localhost:8787
# Render: https://your-app.onrender.com
BETTER_AUTH_URL=http://localhost:8787

# ── CORS ─────────────────────────────────────────────────────────────────────
# URL of the frontend (Next.js web app)
# Local: http://localhost:3001
# Vercel: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3001

# ── LLM Provider ──────────────────────────────────────────────────────────────
# "groq"      → free, uses JSON mode, good for dev/smoke tests
# "anthropic" → required for final submission (tool use + prompt caching)
LLM_PROVIDER=groq

# ── Anthropic (required if LLM_PROVIDER=anthropic) ───────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Groq (required if LLM_PROVIDER=groq) ─────────────────────────────────────
# Free tier available at: https://console.groq.com
GROQ_API_KEY=gsk_YOUR_KEY_HERE
