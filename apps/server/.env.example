# LLM Provider
# "anthropic" = Anthropic Claude (full assignment compliance, prompt caching)
# "groq"      = Groq (free, fast, no prompt caching — good for dev/testing)
LLM_PROVIDER=anthropic

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ── Groq ──────────────────────────────────────────────────────────────────────
# Required when LLM_PROVIDER=groq
# Free API key at https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/healosbench

# ── Better Auth ───────────────────────────────────────────────────────────────
# Must be at least 32 characters
BETTER_AUTH_SECRET=your-32-char-secret-here-change-in-prod
BETTER_AUTH_URL=http://localhost:8787
CORS_ORIGIN=http://localhost:3000
